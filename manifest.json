{
  "manifest_version": 2,
  "name": "Privacy Monitor",
  "version": "1.0",
  "description": "Detecta rastreamento e ameaças à privacidade",
  "icons": { "48": "icons/icon48.png", "96": "icons/icon96.png" },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png",
    "default_badge_text": ""
  },
  "background": { "scripts": ["background.js"] },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["privacy_monitor.js"],
    "run_at": "document_start",
    "all_frames": true
  }],
  "permissions": [
    "webRequest", "webRequestBlocking",
    "cookies", "storage",
    "tabs", "activeTab",
    "<all_urls>"
  ],
  "data_collection_permissions": {
    "collects_website_data": true,
    "purpose": "Privacy analysis only, no data leaves the browser"
  }
}